 	uintptr_t wr_id;
 	int i, err = 0;
 
+	perf_start();
+
 	if (flags & FI_INJECT) {
 		EFA_WARN(FI_LOG_EP_DATA,
 			 "FI_INJECT is not supported by efa rma yet.\n");
@@ -236,6 +281,7 @@ static inline ssize_t efa_rma_post_write(struct efa_base_ep *base_ep,
 	efa_tracepoint(post_write, wr_id, (uintptr_t)msg->context);
 
 out_err:
+	perf_stop();
 	ofi_genlock_unlock(&base_ep->util_ep.lock);
 	return err;
 }
