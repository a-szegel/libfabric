+#include <linux/perf_event.h>
+#include <sys/syscall.h>
+#include <unistd.h>
+#include <sys/ioctl.h>
+
+static int perf_cache_miss_fd = -1;
+static uint64_t total_cache_misses = 0;
+static uint64_t total_calls = 0;
+
+static void init_perf_counter(void) {
+    struct perf_event_attr pe = {
+        .type = PERF_TYPE_HARDWARE,
+        .size = sizeof(struct perf_event_attr),
+        .config = PERF_COUNT_HW_CACHE_MISSES,
+        .disabled = 1,
+        .exclude_kernel = 1,
+        .exclude_hv = 1,
+    };
+    
+    perf_cache_miss_fd = syscall(__NR_perf_event_open, &pe, 0, -1, -1, 0);
+    if (perf_cache_miss_fd < 0) {
+        EFA_WARN(FI_LOG_EP_DATA, "Failed to open perf counter: %d\n", errno);
+    }
+}
+
+static inline void perf_start(void) {
+    if (perf_cache_miss_fd >= 0) {
+        ioctl(perf_cache_miss_fd, PERF_EVENT_IOC_RESET, 0);
+        ioctl(perf_cache_miss_fd, PERF_EVENT_IOC_ENABLE, 0);
+    }
+}
+
+static inline void perf_stop(void) {
+    if (perf_cache_miss_fd >= 0) {
+        uint64_t count;
+        ioctl(perf_cache_miss_fd, PERF_EVENT_IOC_DISABLE, 0);
+        read(perf_cache_miss_fd, &count, sizeof(count));
+        total_cache_misses += count;
+        total_calls++;
+        if (total_calls % 1000 == 0)
+            EFA_INFO(FI_LOG_EP_DATA, "RMA write: %lu calls, avg cache misses: %lu\n", total_calls, total_cache_misses / total_calls);
+    }
+}
+
 #include "efa.h"
 #include "efa_av.h"
 #include "efa_rdm_msg.h"
